rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla para permitir lectura/escritura solo al usuario autenticado en su propia subcolección
    match /dtbitacora/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regla para colección careers - lectura para todos autenticados, escritura solo para admins
    match /careers/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Regla para colección admins - solo el propio usuario puede leer su doc (contiene passwordHash)
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Solo se puede crear manualmente desde Firebase Console
    }

    // Carrera seleccionada por cada usuario - usada para autorizar el acceso
    // a sharedTasks/{careerId} según pertenencia.
    match /userCareers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tareas pendientes compartidas por carrera (ej: Teología) - solo los
    // usuarios autenticados que tienen esa carrera seleccionada
    // (userCareers/{uid}.careerId == careerId) pueden leer/escribir.
    match /sharedTasks/{careerId}/tasks/{taskId} {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/userCareers/$(request.auth.uid))
        && get(/databases/$(database)/documents/userCareers/$(request.auth.uid)).data.careerId == careerId;
    }

    // Progreso personal (Realizada/Enviada) por usuario y tarea - privado, se
    // sincroniza entre los dispositivos del mismo usuario.
    match /userProgress/{userId}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
